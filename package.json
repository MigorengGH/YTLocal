{
  "name": "ytlocal",
  "version": "1.0.0",
  "description": "A desktop app to download YouTube videos and audio locally.",
  "main": "main.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "postinstall": "node scripts/postinstall.js",
    "start": "electron .",
    "dist": "CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder",
    "dist:win": "electron-builder --win"
  },
  "build": {
    "appId": "com.ytlocal.app",
    "productName": "YTLocal",
    "extraResources": [
      {
        "from": "bin/",
        "to": "bin",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "target": [
        "dmg"
      ],
      "identity": null,
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3"
  },
  "dependencies": {
    "ffmpeg-static": "^5.3.0",
    "youtube-dl-exec": "^3.1.9"
  }
}
